generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ACCOUNTANT
  JUNIOR
}

enum ReportStatus {
  PROCESSING
  COMPLETE
  FAILED
}

enum IssueSeverity {
  CRITICAL
  WARNING
  NOTICE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  firmId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  firm               Firm                @relation(fields: [firmId], references: [id])
  reportsCreated     Report[]
  auditLogs          AuditLog[]
  verificationTokens VerificationToken[]

  @@index([firmId])
}

model Firm {
  id         String   @id @default(cuid())
  name       String
  scansUsed  Int      @default(0)
  scansLimit Int      @default(3)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users        User[]
  clients      Client[]
  reports      Report[]
  auditLogs    AuditLog[]
  subscription Subscription?
}

model Client {
  id        String   @id @default(cuid())
  name      String
  firmId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firm    Firm     @relation(fields: [firmId], references: [id])
  reports Report[]

  @@index([firmId])
  @@index([firmId, name])
}

model Report {
  id                String       @id @default(cuid())
  clientId          String
  firmId            String
  createdById       String
  period            String
  status            ReportStatus
  totalIssues       Int
  criticalCount     Int
  warningCount      Int
  noticeCount       Int
  promptVersionHash String
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  client    Client   @relation(fields: [clientId], references: [id])
  firm      Firm     @relation(fields: [firmId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])
  issues    Issue[]

  @@index([clientId])
  @@index([clientId, createdAt(sort: Desc)])
  @@index([status])
}

model Issue {
  id                String        @id @default(cuid())
  reportId          String
  severity          IssueSeverity
  title             String
  description       String
  recommendedAction String
  transactionRef    String
  resolved          Boolean       @default(false)
  resolutionNote    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  report Report @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([reportId, severity])
}

model AuditLog {
  id              String   @id @default(cuid())
  firmId          String
  userId          String
  action          String
  metadata        Json
  ipAddress       String
  rejectedFinding Json?
  rejectionReason String?
  createdAt       DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([firmId, createdAt(sort: Desc)])
}

model Subscription {
  id               String             @id @default(cuid())
  firmId           String             @unique
  paddleSubId      String             @unique
  status           SubscriptionStatus
  currentPeriodEnd DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  firm Firm @relation(fields: [firmId], references: [id])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])
}
